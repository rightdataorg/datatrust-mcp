# Optional local overrides for datatrust-mcp (copy to .env — never commit .env).
# Normal users do NOT need this file. Run `datatrust-mcp setup <manifest-url>` instead.

# Single shared-token mode (one API token authenticates the whole MCP — no
# per-user OAuth). Mint a service token (dtmcp_svc_*) in DataTrust via the MCP
# admin UI, then set both vars below. Every tool call is authenticated by this
# one token; results are returned with the token's full access (per-user result
# scoping is not applied in this mode). Also usable for CI / automation.
# DATATRUST_API_KEY=dtmcp_svc_xxxxxxxxxxxxxxxx
# DATATRUST_MCP_ALLOW_SHARED_KEY=1

# Optional: identify this laptop in audit logs (default: claude-desktop)
# DATATRUST_MCP_CLIENT_NAME=cursor

# Optional: device (default) or loopback OAuth on plain-HTTP dev hosts
# DATATRUST_MCP_AUTH_MODE=device

# Optional: corporate CA bundle for manifest fetch (self-signed TLS)
# DATATRUST_CA_BUNDLE=/path/to/corp-ca.pem

# Optional: upstream timeout seconds (default 180)
# DATATRUST_HTTP_TIMEOUT=180
